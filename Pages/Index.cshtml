@page
@model LoginModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Login - Ponto SaaS";
}

<div class="min-h-screen bg-[#f5f5f5] flex flex-col items-center justify-center px-6">

    <!-- Logo -->
    <div class="w-full max-w-sm mb-8">
        <img 
            src="/images/logo.png" 
            alt="Logo" 
            class="w-full rounded-2xl shadow-md object-cover"
            onerror="this.src='https://via.placeholder.com/400x250?text=Logo';" />
    </div>

    <!-- Form -->
    <div class="w-full max-w-sm space-y-6">

        <!-- Email -->
        <div>
            <label class="block text-lg font-semibold text-black mb-2">
                E-mail
            </label>
            <input asp-for="Email"
                   class="w-full px-5 py-4 rounded-full bg-[#c7d9d8] text-gray-800 placeholder-gray-500 focus:outline-none"
                   placeholder="seu@email.com"
                   required />
        </div>

        <!-- Senha -->
        <div>
            <label class="block text-lg font-semibold text-black mb-2">
                Senha
            </label>
            <input asp-for="Senha" type="password"
                   class="w-full px-5 py-4 rounded-full bg-[#c7d9d8] text-gray-800 placeholder-gray-500 focus:outline-none"
                   placeholder="••••••••"
                   required />
        </div>

        <!-- Erro -->
        @if (Model.Erro != null)
        {
            <div class="text-red-600 text-sm text-center">
                @Model.Erro
            </div>
        }

        <!-- Botão -->
        <button type="submit"
                class="w-full py-4 rounded-full text-white font-semibold text-lg bg-[#1f7f86] hover:opacity-90 transition">
            Entrar
        </button>

        <!-- Esqueci senha -->
        <div class="text-center">
            <a href="#" class="text-[#1f7f86] font-medium hover:underline">
                Esqueci a senha
            </a>
        </div>
    </div>

    <!-- Rodapé -->
    <div class="mt-10 text-center text-black font-semibold">
        Sem acesso? Contate seu gestor
    </div>

</div>