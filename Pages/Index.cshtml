@page
@model LoginModel
@{
    Layout = "_LayoutLogin";   // ou o nome que você escolher
}
@{
    ViewData["Title"] = "Login - Ponto SaaS";
}

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-2xl shadow-lg border border-gray-100">
        
        <!-- Logo -->
        <div class="flex justify-center">
            <img 
                src="/images/logo.png" 
                alt="Ponto SaaS Logo" 
                class="h-16 w-auto object-contain" 
                onerror="this.src='https://via.placeholder.com/180x60?text=Logo';" />
        </div>

        <!-- Título -->
        <div class="text-center">
            <h2 class="mt-4 text-3xl font-bold text-gray-900">
                Bem-vindo de volta
            </h2>
            <p class="mt-2 text-sm text-gray-600">
                Faça login para acessar o sistema de ponto
            </p>
        </div>

        <!-- Formulário -->
        <form method="post" class="mt-8 space-y-6">
            <!-- Erro -->
            @if (Model.Erro != null)
            {
                <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg">
                    <p class="text-sm text-red-700">@Model.Erro</p>
                </div>
            }

            <!-- Email -->
            <div>
                <label for="Email" class="block text-sm font-medium text-gray-700">
                    Email
                </label>
                <div class="mt-1">
                    <input asp-for="Email" 
                           class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary sm:text-sm transition duration-150 ease-in-out"
                           placeholder="seu@email.com" 
                           required />
                </div>
            </div>

            <!-- Senha -->
            <div>
                <label for="Senha" class="block text-sm font-medium text-gray-700">
                    Senha
                </label>
                <div class="mt-1">
                    <input asp-for="Senha" type="password"
                           class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary sm:text-sm transition duration-150 ease-in-out"
                           placeholder="••••••••" 
                           required />
                </div>
            </div>

            <!-- Botão -->
            <div>
                <button type="submit"
                        class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-semibold rounded-lg text-white bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition duration-150 ease-in-out">
                    Entrar
                </button>
            </div>
        </form>

        <!-- Links extras (opcional, pode remover ou customizar) -->
        <div class="text-center text-sm text-gray-500 mt-6">
            <a href="#" class="text-primary hover:underline">Esqueci minha senha</a>
            <span class="mx-2">•</span>
            <a href="#" class="text-primary hover:underline">Criar conta</a>
        </div>
    </div>
</div>