@page
@model PontoSaaS.Pages.Admin.PontosDiaModel

@{
    ViewData["Title"] = "Pontos do Dia";
}

<div class="max-w-7xl mx-auto">
    <!-- Cabeçalho -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Pontos do Dia</h1>
            <p class="text-gray-600 mt-1">
                @Model.NomeEmpresa
                @if (Model.NomeFuncionario != null)
                {
                    <span class="text-gray-500"> • @Model.NomeFuncionario</span>
                }
            </p>
        </div>

        <!-- Filtro de data (simples por enquanto) -->
        <div class="flex items-center gap-3">
            <form method="get" class="flex items-center gap-2">
                <input type="hidden" name="empresaId" value="@Model.EmpresaId" />
                @if (Model.UsuarioId.HasValue)
                {
                    <input type="hidden" name="usuarioId" value="@Model.UsuarioId" />
                }
                <input type="date" name="data" value="@Model.DataSelecionada.ToString("yyyy-MM-dd")"
                       class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-primary focus:border-primary" />
                <button type="submit"
                        class="bg-gray-800 text-white px-4 py-2 rounded-lg hover:bg-gray-900 transition text-sm font-medium">
                    Filtrar
                </button>
            </form>
        </div>
    </div>

    <!-- Card principal -->
    <div class="bg-white shadow-sm rounded-2xl border border-gray-200 overflow-hidden">
        <!-- Cabeçalho da tabela -->
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-800">
                Registros de @Model.DataSelecionada.ToString("dd 'de' MMMM 'de' yyyy")
                (@Model.Registros.Count registros encontrados)
            </h2>
        </div>

        @if (!Model.Registros.Any())
        {
            <div class="p-12 text-center text-gray-500">
                Nenhum registro de ponto encontrado para esta data.
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Funcionário</th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Hora</th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo</th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Data/Hora completa</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-100">
                        @foreach (var r in Model.Registros)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900">@r.FuncionarioNome</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-900 font-mono">@r.HoraFormatada</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        @(r.Tipo switch
                                        {
                                            "Entrada" => "bg-green-100 text-green-800",
                                            "Saida" => "bg-red-100 text-red-800",
                                            "InicioIntervalo" => "bg-yellow-100 text-yellow-800",
                                            "FimIntervalo" => "bg-blue-100 text-blue-800",
                                            _ => "bg-gray-100 text-gray-800"
                                        })">
                                        @r.Tipo
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @r.DataHora.ToString("dd/MM/yyyy HH:mm:ss")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Botões de ação -->
    <div class="mt-8 flex flex-wrap gap-4">
        <a href="/Admin/Dashboard?empresaId=@Model.EmpresaId"
           class="inline-flex items-center px-5 py-3 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition">
            ← Voltar para funcionários
        </a>

        <a href="/Admin/Dashboard"
           class="inline-flex items-center px-5 py-3 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition">
            Voltar ao Dashboard
        </a>
    </div>
</div>